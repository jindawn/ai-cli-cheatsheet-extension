{
  "schemaVersion": 1,
  "adapters": {
    "antigravity-cli": { "kind": "structured-docs-repository", "version": 1, "sourceIds": ["antigravity-announcement", "antigravity-repository"] },
    "claude-code": { "kind": "structured-docs-repository", "version": 1, "sourceIds": ["claude-interactive", "claude-commands"] },
    "codex": { "kind": "structured-docs-repository", "version": 1, "sourceIds": ["codex-slash-commands", "codex-cli-reference", "codex-features"] },
    "cursor": { "kind": "default-keymap-table", "version": 1, "sourceIds": ["cursor-shortcuts"], "platforms": ["mac", "windows", "linux"] },
    "docker": { "kind": "recursive-cli-reference", "version": 2, "sourceIds": ["docker-docs", "docker-help"] },
    "gemini-cli": { "kind": "structured-docs-repository", "version": 1, "sourceIds": ["gemini-commands", "gemini-keyboard" ] },
    "git": { "kind": "recursive-help-docs", "version": 1, "sourceIds": ["git-docs"] },
    "homebrew": { "kind": "recursive-help-docs", "version": 1, "sourceIds": ["brew-help", "brew-docs"] },
    "idea": { "kind": "default-keymap-table", "version": 1, "sourceIds": ["idea-macos-keymap"], "platforms": ["mac", "windows", "linux"] },
    "iterm2": { "kind": "terminal-reference-keymap", "version": 1, "sourceIds": ["iterm2-docs", "iterm2-local-help"], "platforms": ["mac", "windows", "linux"] },
    "linux": {
      "kind": "fixed-official-component-union",
      "version": 1,
      "sourceIds": ["gnu-manuals"],
      "components": ["gnu-coreutils", "gnu-findutils", "gnu-grep", "gnu-sed", "gnu-gawk", "gnu-diffutils", "gnu-tar", "procps-ng", "util-linux", "iputils", "openssh-client", "curl", "wget", "less"]
    },
    "obsidian": { "kind": "default-keymap-table", "version": 1, "sourceIds": ["obsidian-help"], "platforms": ["mac", "windows", "linux"] },
    "openclaw": { "kind": "structured-docs-repository", "version": 1, "sourceIds": ["openclaw-slash", "openclaw-cli"] },
    "opencode": { "kind": "structured-docs-repository", "version": 1, "sourceIds": ["opencode-tui", "opencode-keybinds", "opencode-cli"] },
    "shell": {
      "kind": "fixed-official-component-union",
      "version": 1,
      "sourceIds": ["posix-shell-utilities", "gnu-bash-manual", "zsh-manual", "bash-local-help"],
      "components": ["posix-shell", "bash", "zsh"]
    },
    "typora": { "kind": "default-keymap-table", "version": 1, "sourceIds": ["typora-shortcuts"], "platforms": ["mac", "windows", "linux"] },
    "vs-code": { "kind": "default-keymap-table", "version": 1, "sourceIds": ["vscode-keybindings"], "platforms": ["mac", "windows", "linux"] }
  }
}
