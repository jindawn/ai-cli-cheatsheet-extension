{
  "_comment": "浏览器校验器与 Native Host 共同读取的校验契约。",
  "limits": { "maxItems": 2000, "maxFieldLength": 4000 },
  "keywords": { "min": 3, "max": 8 },
  "examples": { "max": 3 },
  "categories": ["shortcut", "slash", "flag"],
  "platforms": ["mac", "windows", "linux"],
  "updatePolicies": ["version-driven", "release-driven", "manual-only"],
  "exampleSourceTypes": ["official", "quasi-official", "manual", "ai-derived"],
  "sourceTiers": ["official", "quasi-official", "community"],
  "sourceKinds": ["local-help", "official-doc", "official-repository", "release-notes", "authoritative-reference", "community"],
  "authorships": ["official", "editorial", "generated"],
  "evidenceTiers": ["first-party", "authoritative-community", "community", "none"],
  "adaptations": ["verbatim", "adapted", "scenario-derived"],
  "evidenceStatuses": ["verified", "partial", "unverified"],
  "evidenceClaims": ["existence", "semantics", "platform", "example"],
  "officialCoverageStatuses": ["complete", "unconfirmed"],
  "officialCoverageScope": "all-command-entrypoints",
  "groundingClaims": ["value", "behavior", "expected", "platform", "prerequisite", "caveat"],
  "scenarioQuality": {
    "reviewVersion": "scenario-grounding-v2",
    "requiredFields": ["scenario", "goal", "value", "description", "expected"],
    "maxRepeatedText": 3,
    "forbiddenPhrases": [
      "需要确认当前 Docker 版本是否支持",
      "需要确认当前版本是否支持",
      "打开该命令的本机帮助而不执行实际操作",
      "终端显示 Usage、Options 和命令说明",
      "当前交互流程中需要",
      "保留终端中的执行记录",
      "工具执行“",
      "若条件不满足",
      "这一具体操作"
    ],
    "placeholderPattern": "\\b(?:CONTAINER|IMAGE|SERVICE|NETWORK|VOLUME|NODE|SECRET|CONFIG|PLUGIN|CONTEXT|COMMAND|FILE)\\b"
  },
  "qualityGates": {
    "coreTools": ["antigravity-cli", "claude-code", "codex", "gemini-cli", "openclaw", "opencode"],
    "coreVerifiedRatio": 0.9,
    "defaultVerifiedRatio": 0.75,
    "newItemVerifiedRatio": 1,
    "highRiskVerifiedRatio": 0.9,
    "maxUnexplainedUnverified": 0,
    "maxRegressionPoints": 0.02,
    "temporaryTargetExceptions": {
      "antigravity-cli": "官方详细命令参考尚未覆盖迁移期候选；仅保留已有明确隔离标记的数据",
      "obsidian": "官方帮助没有稳定的逐条默认键位定位；快捷键作为待人工复核子集隔离"
    }
  },
  "shell": {
    "layers": ["syntax", "keyword", "builtin", "option", "shortcut", "config"],
    "portabilities": ["posix", "bash", "zsh", "cross-platform"],
    "topics": ["builtins", "syntax", "shortcuts", "config", "environment", "history", "completion", "scripting", "jobs", "troubleshooting"]
  },
  "dangerousExample": {
    "source": "(?:\\brm(?:\\s|$)|\\bdd\\s+(?:if|of|bs|count|conv|status|seek|skip)=|\\b(?:reset\\s+--hard|push\\s+--force|kill\\s+-9|chmod|chown|restart|shutdown|reboot|halt|poweroff|mkfs)\\b|--(?:delete|yolo)\\b|dangerously-bypass\\b|:\\(\\)\\s*\\{\\s*:)|(^|\\s)>(?!>)",
    "flags": "i"
  },
  "riskLevels": {
    "deleteOrOverwrite": "(?:\\brm(?:\\s|$)|\\bdd\\s+(?:if|of|bs|count|conv|status|seek|skip)=|\\b(?:reset\\s+--hard|mkfs)\\b|--delete\\b)|(^|\\s)>(?!>)",
    "permissionChange": "\\b(chmod|chown)\\b",
    "historyRewrite": "\\b(reset\\s+--hard|push\\s+--force|rebase\\s+-i)\\b",
    "safetyBypass": "(?:--yolo|dangerously-bypass|bypassPermissions)\\b",
    "remoteExecution": "\\b(curl|wget)\\b[^|\\n]*\\|\\s*(sudo\\s+)?(ba)?sh\\b|:\\(\\)\\s*\\{\\s*:",
    "processDisruption": "\\b(kill\\s+-9|restart|shutdown|reboot|halt|poweroff)\\b"
  },
  "possibleSecret": {
    "source": "(?:api[_-]?key|secret|token)\\s*[=:]\\s*[a-z0-9_-]{12,}",
    "flags": "i"
  }
}
